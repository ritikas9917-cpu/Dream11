<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dream11 Rewards – Play Games & Earn Daily</title>
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;600;700;800&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --primary: #FF6B2B;
    --secondary: #FFD700;
    --accent: #00D4FF;
    --purple: #7C3AED;
    --green: #10B981;
    --pink: #F43F5E;
    --dark: #0F0A1E;
    --dark2: #1A1035;
    --dark3: #251848;
    --card: rgba(255,255,255,0.06);
    --card-border: rgba(255,255,255,0.12);
    --text: #F0ECF8;
    --text-muted: #A89CC8;
    --radius: 20px;
    --font-head: 'Baloo 2', cursive;
    --font-body: 'Nunito', sans-serif;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: var(--font-body);
    background: var(--dark);
    color: var(--text);
    overflow-x: hidden;
    line-height: 1.6;
  }

  /* ── BACKGROUND MESH ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 50% at 10% 10%, rgba(124,58,237,.35) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 90% 80%, rgba(255,107,43,.25) 0%, transparent 55%),
      radial-gradient(ellipse 50% 40% at 50% 50%, rgba(0,212,255,.12) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  /* ── NAV ── */
  nav {
    position: sticky; top: 0; z-index: 100;
    background: rgba(15,10,30,.85);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid var(--card-border);
    padding: 0 24px;
  }
  .nav-inner {
    max-width: 1200px; margin: auto;
    display: flex; align-items: center; justify-content: space-between;
    height: 64px;
  }
  .logo {
    font-family: var(--font-head);
    font-size: 1.5rem; font-weight: 800;
    background: linear-gradient(135deg, var(--secondary), var(--primary));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    text-decoration: none;
  }
  .logo span { -webkit-text-fill-color: var(--accent); }
  .nav-links {
    display: flex; gap: 4px; list-style: none;
  }
  .nav-links a {
    color: var(--text-muted); text-decoration: none;
    font-size: .9rem; font-weight: 600;
    padding: 6px 14px; border-radius: 50px;
    transition: all .2s;
  }
  .nav-links a:hover { color: #fff; background: var(--card); }
  .nav-cta {
    background: linear-gradient(135deg, var(--primary), #FF3D6F);
    color: #fff !important; border-radius: 50px !important;
    padding: 8px 20px !important;
  }
  .nav-cta:hover { transform: translateY(-1px); box-shadow: 0 8px 24px rgba(255,107,43,.4) !important; background: var(--card) !important; }
  .hamburger { display: none; background: none; border: none; cursor: pointer; color: #fff; font-size: 1.6rem; }
  .mobile-menu {
    display: none; flex-direction: column; gap: 4px;
    background: var(--dark2); padding: 12px 24px 16px;
    border-bottom: 1px solid var(--card-border);
  }
  .mobile-menu a { color: var(--text-muted); text-decoration: none; font-weight: 600; padding: 10px 0; border-bottom: 1px solid var(--card-border); }
  .mobile-menu a:last-child { border: none; }
  .mobile-menu.open { display: flex; }

  /* ── AD BANNER ── */
  .ad-banner {
    background: linear-gradient(90deg, rgba(124,58,237,.2), rgba(0,212,255,.1));
    border: 1px dashed rgba(0,212,255,.3);
    border-radius: 10px;
    text-align: center;
    padding: 14px;
    color: var(--text-muted);
    font-size: .85rem;
    margin: 16px auto;
    max-width: 728px;
  }
  .ad-banner strong { color: var(--accent); font-size: .75rem; text-transform: uppercase; letter-spacing: 1px; display: block; margin-bottom: 4px; }

  /* ── SECTIONS ── */
  section { position: relative; z-index: 1; padding: 80px 24px; }
  .container { max-width: 1200px; margin: auto; }
  .section-label {
    display: inline-block;
    font-size: .75rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
    color: var(--accent); background: rgba(0,212,255,.12);
    border: 1px solid rgba(0,212,255,.25); border-radius: 50px;
    padding: 4px 16px; margin-bottom: 14px;
  }
  h2 {
    font-family: var(--font-head); font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800;
    line-height: 1.2; margin-bottom: 16px;
  }
  .section-sub { color: var(--text-muted); max-width: 580px; font-size: 1.05rem; margin-bottom: 48px; }

  /* ── HERO ── */
  #home {
    min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; padding: 100px 24px 60px;
    background: radial-gradient(ellipse 80% 60% at 50% 30%, rgba(124,58,237,.2) 0%, transparent 70%);
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(255,215,0,.1); border: 1px solid rgba(255,215,0,.3);
    border-radius: 50px; padding: 6px 18px;
    font-size: .85rem; font-weight: 700; color: var(--secondary);
    margin-bottom: 28px; animation: fadeUp .6s both;
  }
  .hero-badge .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--secondary); animation: pulse 1.5s infinite; }
  h1 {
    font-family: var(--font-head); font-size: clamp(2.4rem, 7vw, 5rem); font-weight: 800;
    line-height: 1.1; margin-bottom: 24px;
    animation: fadeUp .7s .1s both;
  }
  .h1-grad { background: linear-gradient(135deg, #fff 30%, var(--secondary) 70%, var(--primary) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .hero-sub {
    color: var(--text-muted); font-size: 1.1rem; max-width: 560px; margin: 0 auto 40px;
    animation: fadeUp .7s .2s both;
  }
  .hero-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; animation: fadeUp .7s .3s both; }
  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--font-body); font-weight: 700; font-size: 1rem;
    padding: 14px 32px; border-radius: 50px; border: none; cursor: pointer;
    text-decoration: none; transition: all .25s;
  }
  .btn-primary { background: linear-gradient(135deg, var(--primary) 0%, #FF3D6F 100%); color: #fff; box-shadow: 0 12px 32px rgba(255,107,43,.4); }
  .btn-primary:hover { transform: translateY(-3px); box-shadow: 0 20px 40px rgba(255,107,43,.5); }
  .btn-secondary { background: var(--card); border: 1px solid var(--card-border); color: #fff; }
  .btn-secondary:hover { background: rgba(255,255,255,.12); transform: translateY(-2px); }
  .hero-stats {
    display: flex; gap: 40px; justify-content: center; flex-wrap: wrap;
    margin-top: 60px; animation: fadeUp .8s .4s both;
  }
  .stat { text-align: center; }
  .stat-num { font-family: var(--font-head); font-size: 2rem; font-weight: 800; color: var(--secondary); }
  .stat-label { font-size: .8rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; }
  .floating-coins {
    position: absolute; inset: 0; pointer-events: none; overflow: hidden;
  }
  .coin {
    position: absolute; font-size: 1.8rem; opacity: .25;
    animation: floatCoin linear infinite;
  }

  /* ── GAMES ── */
  #games { background: linear-gradient(180deg, transparent, rgba(124,58,237,.08) 50%, transparent); }
  .games-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 24px;
  }
  .game-card {
    background: var(--card); border: 1px solid var(--card-border);
    border-radius: var(--radius); padding: 32px 24px;
    text-align: center; cursor: pointer;
    transition: all .3s; position: relative; overflow: hidden;
  }
  .game-card::before {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(135deg, var(--glow, rgba(255,107,43,.15)), transparent);
    opacity: 0; transition: opacity .3s;
  }
  .game-card:hover { transform: translateY(-8px); border-color: rgba(255,255,255,.22); box-shadow: 0 24px 48px rgba(0,0,0,.4); }
  .game-card:hover::before { opacity: 1; }
  .game-icon {
    width: 80px; height: 80px; border-radius: 24px;
    display: flex; align-items: center; justify-content: center;
    font-size: 2.2rem; margin: 0 auto 20px;
    position: relative;
  }
  .game-card h3 { font-family: var(--font-head); font-size: 1.3rem; font-weight: 700; margin-bottom: 8px; }
  .game-card p { color: var(--text-muted); font-size: .9rem; margin-bottom: 20px; }
  .game-tag {
    display: inline-block; font-size: .75rem; font-weight: 700;
    padding: 4px 14px; border-radius: 50px;
    background: rgba(255,255,255,.08); color: var(--text-muted);
  }
  .play-btn {
    display: inline-flex; align-items: center; gap: 6px;
    margin-top: 16px; background: rgba(255,255,255,.1);
    border: 1px solid rgba(255,255,255,.15); color: #fff;
    font-weight: 700; font-size: .85rem; padding: 8px 20px;
    border-radius: 50px; cursor: pointer; transition: all .2s; text-decoration: none;
  }
  .play-btn:hover { background: var(--primary); border-color: var(--primary); }

  /* ── REWARDS ── */
  #rewards { }
  .rewards-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }
  .reward-card {
    background: var(--card); border: 1px solid var(--card-border);
    border-radius: var(--radius); padding: 28px;
    display: flex; align-items: flex-start; gap: 20px;
    transition: all .25s;
  }
  .reward-card:hover { transform: translateY(-4px); border-color: rgba(255,215,0,.3); box-shadow: 0 16px 40px rgba(0,0,0,.35); }
  .reward-icon {
    width: 60px; height: 60px; min-width: 60px;
    border-radius: 16px; display: flex; align-items: center; justify-content: center;
    font-size: 1.8rem;
  }
  .reward-card h3 { font-family: var(--font-head); font-weight: 700; margin-bottom: 6px; }
  .reward-card p { color: var(--text-muted); font-size: .9rem; }
  .coins-bar { margin-top: 48px; background: var(--dark2); border-radius: var(--radius); padding: 32px; border: 1px solid var(--card-border); }
  .coins-bar h3 { font-family: var(--font-head); font-size: 1.4rem; margin-bottom: 24px; }
  .coin-items { display: flex; flex-wrap: wrap; gap: 16px; }
  .coin-item {
    flex: 1; min-width: 140px;
    background: var(--card); border: 1px solid var(--card-border);
    border-radius: 14px; padding: 16px; text-align: center;
  }
  .coin-item .amt { font-family: var(--font-head); font-size: 1.5rem; font-weight: 800; color: var(--secondary); }
  .coin-item .lbl { font-size: .8rem; color: var(--text-muted); margin-top: 2px; }

  /* ── LEADERBOARD ── */
  #leaderboard { background: linear-gradient(180deg, transparent, rgba(0,212,255,.05) 50%, transparent); }
  .leaderboard-table { width: 100%; border-collapse: collapse; }
  .leaderboard-table th {
    text-align: left; padding: 14px 20px;
    font-size: .8rem; text-transform: uppercase; letter-spacing: 1px;
    color: var(--text-muted); border-bottom: 1px solid var(--card-border);
  }
  .leaderboard-table td { padding: 16px 20px; border-bottom: 1px solid rgba(255,255,255,.04); font-size: .95rem; }
  .leaderboard-table tr:hover td { background: rgba(255,255,255,.03); }
  .rank { font-family: var(--font-head); font-weight: 800; font-size: 1.1rem; }
  .rank-1 { color: #FFD700; } .rank-2 { color: #C0C0C0; } .rank-3 { color: #CD7F32; }
  .avatar { width: 38px; height: 38px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
  .player-info { display: flex; align-items: center; gap: 12px; }
  .player-name { font-weight: 700; }
  .player-city { font-size: .8rem; color: var(--text-muted); }
  .score-badge { background: rgba(255,215,0,.15); border: 1px solid rgba(255,215,0,.3); color: var(--secondary); font-weight: 700; padding: 4px 14px; border-radius: 50px; font-size: .85rem; }
  .lb-wrap { background: var(--dark2); border: 1px solid var(--card-border); border-radius: var(--radius); overflow: hidden; }

  /* ── INVITE ── */
  #invite { }
  .invite-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; }
  .invite-steps { display: flex; flex-direction: column; gap: 20px; }
  .invite-step { display: flex; align-items: flex-start; gap: 16px; }
  .step-num {
    min-width: 44px; height: 44px; border-radius: 14px;
    background: linear-gradient(135deg, var(--purple), var(--primary));
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-head); font-weight: 800; font-size: 1.1rem;
  }
  .step-text h4 { font-weight: 700; margin-bottom: 4px; }
  .step-text p { color: var(--text-muted); font-size: .9rem; }
  .invite-card {
    background: linear-gradient(135deg, rgba(124,58,237,.3), rgba(255,107,43,.2));
    border: 1px solid var(--card-border);
    border-radius: var(--radius); padding: 40px 32px; text-align: center;
  }
  .invite-card .big-num { font-family: var(--font-head); font-size: 4rem; font-weight: 800; color: var(--secondary); line-height: 1; }
  .invite-card .big-label { color: var(--text-muted); margin-bottom: 24px; font-size: .9rem; }
  .referral-code {
    background: var(--dark); border: 2px dashed var(--card-border);
    border-radius: 14px; padding: 16px; font-family: monospace;
    font-size: 1.4rem; font-weight: 700; letter-spacing: 4px; color: var(--accent); margin-bottom: 16px;
    cursor: pointer; transition: border-color .2s;
  }
  .referral-code:hover { border-color: var(--accent); }

  /* ── ABOUT ── */
  #about { background: linear-gradient(180deg, transparent, rgba(124,58,237,.07) 50%, transparent); }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
  .about-feature { display: flex; align-items: flex-start; gap: 14px; margin-bottom: 24px; }
  .feat-icon { font-size: 1.6rem; min-width: 40px; }
  .feat-text h4 { font-weight: 700; margin-bottom: 4px; }
  .feat-text p { color: var(--text-muted); font-size: .9rem; }
  .about-visual {
    background: var(--card); border: 1px solid var(--card-border);
    border-radius: var(--radius); padding: 40px; text-align: center;
    position: relative; overflow: hidden;
  }
  .about-visual::after {
    content: ''; position: absolute;
    width: 200px; height: 200px; border-radius: 50%;
    background: radial-gradient(circle, rgba(124,58,237,.3), transparent);
    top: -60px; right: -60px;
  }
  .app-preview { font-size: 5rem; margin-bottom: 20px; }

  /* ── CONTACT ── */
  #contact { }
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
  .contact-info { display: flex; flex-direction: column; gap: 20px; margin-bottom: 32px; }
  .contact-item { display: flex; align-items: center; gap: 14px; }
  .c-icon { width: 48px; height: 48px; border-radius: 14px; background: var(--card); border: 1px solid var(--card-border); display: flex; align-items: center; justify-content: center; font-size: 1.3rem; }
  .c-text a { color: var(--accent); text-decoration: none; font-weight: 600; }
  .form-group { margin-bottom: 20px; }
  .form-group label { display: block; font-size: .85rem; font-weight: 700; color: var(--text-muted); margin-bottom: 8px; text-transform: uppercase; letter-spacing: .5px; }
  .form-group input, .form-group textarea {
    width: 100%; background: var(--dark2); border: 1px solid var(--card-border);
    color: #fff; font-family: var(--font-body); font-size: 1rem;
    padding: 14px 18px; border-radius: 14px; outline: none; transition: border-color .2s;
  }
  .form-group input:focus, .form-group textarea:focus { border-color: var(--accent); }
  .form-group textarea { resize: vertical; min-height: 110px; }

  /* ── FOOTER ── */
  footer {
    position: relative; z-index: 1;
    background: var(--dark2); border-top: 1px solid var(--card-border);
    padding: 48px 24px 24px;
  }
  .footer-inner { max-width: 1200px; margin: auto; }
  .footer-top { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 32px; margin-bottom: 40px; }
  .footer-brand p { color: var(--text-muted); font-size: .9rem; margin-top: 12px; max-width: 260px; }
  .footer-col h4 { font-family: var(--font-head); font-weight: 700; margin-bottom: 16px; color: #fff; }
  .footer-col a { display: block; color: var(--text-muted); text-decoration: none; margin-bottom: 10px; font-size: .9rem; transition: color .2s; }
  .footer-col a:hover { color: #fff; }
  .footer-bottom { border-top: 1px solid var(--card-border); padding-top: 24px; display: flex; align-items: center; justify-content: space-between; flex-wrap: gap; color: var(--text-muted); font-size: .85rem; }
  .safe-badge { display: inline-flex; align-items: center; gap: 6px; background: rgba(16,185,129,.12); border: 1px solid rgba(16,185,129,.25); color: var(--green); border-radius: 50px; padding: 4px 14px; font-size: .78rem; font-weight: 700; }

  /* ── TOAST ── */
  .toast {
    position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(80px);
    background: var(--green); color: #fff; padding: 12px 28px; border-radius: 50px;
    font-weight: 700; z-index: 999; transition: transform .35s cubic-bezier(.34,1.56,.64,1);
    pointer-events: none;
  }
  .toast.show { transform: translateX(-50%) translateY(0); }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: none; } }
  @keyframes pulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: .6; transform: scale(.85); } }
  @keyframes floatCoin { 0% { transform: translateY(100vh) rotate(0deg); opacity: 0; } 10% { opacity: .25; } 90% { opacity: .25; } 100% { transform: translateY(-10vh) rotate(360deg); opacity: 0; } }
  @keyframes spinWheel { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  .spin-anim { animation: spinWheel 4s linear infinite; display: inline-block; }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .invite-grid, .about-grid, .contact-grid, .footer-top { grid-template-columns: 1fr; }
    .nav-links { display: none; }
    .hamburger { display: block; }
    .footer-top { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    section { padding: 60px 16px; }
    .hero-stats { gap: 24px; }
    .footer-top { grid-template-columns: 1fr; }
    .footer-bottom { flex-direction: column; gap: 12px; text-align: center; }
  }
</style>
</head>
<body>

<!-- FLOATING COINS -->
<div class="floating-coins" aria-hidden="true" id="coinsContainer"></div>

<!-- TOAST -->
<div class="toast" id="toast">✅ Copied!</div>

<!-- NAV -->
<nav>
  <div class="nav-inner">
    <a href="#home" class="logo">Dream11 <span>Rewards</span></a>
    <ul class="nav-links">
      <li><a href="#games">Games</a></li>
      <li><a href="#rewards">Rewards</a></li>
      <li><a href="#leaderboard">Leaderboard</a></li>
      <li><a href="#invite">Invite</a></li>
      <li><a href="#about">About</a></li>
      <li><a href="#contact">Contact</a></li>
      <li><a href="#home" class="nav-cta">▶ Start Playing</a></li>
    </ul>
    <button class="hamburger" id="menuToggle" aria-label="Menu">☰</button>
  </div>
  <div class="mobile-menu" id="mobileMenu">
    <a href="#games">🎮 Games</a>
    <a href="#rewards">🪙 Rewards</a>
    <a href="#leaderboard">🏆 Leaderboard</a>
    <a href="#invite">👥 Invite & Earn</a>
    <a href="#about">ℹ️ About</a>
    <a href="#contact">📬 Contact</a>
  </div>
</nav>

<!-- AD BANNER -->
<div style="padding:0 24px; position:relative; z-index:1;">
  <div class="ad-banner">
    <strong>📢 Advertisement</strong>
    Your Ad Here – Google AdSense Banner (728×90) — Connect your AdSense account to display ads
  </div>
</div>

<!-- ═══════════════ HERO ═══════════════ -->
<section id="home">
  <div class="hero-badge"><span class="dot"></span> 🎉 New Games Added Weekly!</div>
  <h1><span class="h1-grad">Play Games &<br>Earn Rewards Daily</span></h1>
  <p class="hero-sub">Join thousands of players having fun, competing on leaderboards, and collecting coins every single day — completely free & safe!</p>
  <div class="hero-btns">
